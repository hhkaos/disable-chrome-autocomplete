{
  "manifest_version": 3,
  "name": "Disable Form Autocomplete",
  "version": "1.1.0",
  "description": "Disable Chrome saved address suggestions for cleaner forms, demos, and recordings.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "privacy"
  ],
  "action": {
    "default_title": "Disable Form Autocomplete",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  }
}
